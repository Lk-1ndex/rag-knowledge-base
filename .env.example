# ===== LLM：DeepSeek 官方（默认启用）=====
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
# 思考模式：off（快速，默认）/ on（多步推理，配合 reasoning_effort）
DEEPSEEK_THINKING_MODE=off
DEEPSEEK_REASONING_EFFORT=high

# ===== LLM：可选 OpenAI 兼容网关（设置 OPENAI_API_KEY 后优先于 DeepSeek）=====
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_WIRE_API=responses
# OPENAI_REASONING_EFFORT=high
# OPENAI_DISABLE_RESPONSE_STORAGE=true

# ===== Embedding：硅基流动 SiliconFlow（BGE-M3，免费，OpenAI 兼容）=====
# 注册 https://siliconflow.cn 获取 Key；免费模型用裸名 BAAI/bge-m3（Pro/ 前缀为付费版）
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=BAAI/bge-m3
# BGE-M3 输出维度；切换 embedding 模型时必须同步修改，并与 Qdrant collection 维度一致
EMBEDDING_DIM=1024
# 免费版有并发/批量限制，撞到 "batch too large" 时调小此值
EMBEDDING_BATCH_SIZE=32

# ===== 安全配置 =====
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=请替换为64位随机十六进制字符串
JWT_EXPIRE_DAYS=7
# 生产 HTTPS 环境必须置 true
COOKIE_SECURE=true

# ===== 初始管理员账号 =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请修改为强密码（至少12位，含大小写和数字）

# ===== Qdrant =====
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=research_kb

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== 限流配置 =====
RATE_LIMIT_PER_MINUTE=30
MAX_AUTH_FAILURES=5
AUTH_BAN_MINUTES=15

# ===== 文件上传 =====
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/app/data/uploads

# ===== SQLite =====
SQLITE_PATH=/app/data/sqlite/db.sqlite3
# 文档处理超时（秒）；启动恢复时据此重置残留 processing 文档
DOCUMENT_PROCESSING_TIMEOUT=600

# ===== 应用配置 =====
APP_TITLE=研究组知识库
# 域名与证书邮箱（部署脚本首签证书用）
DOMAIN=your-domain.com
CERTBOT_EMAIL=admin@your-domain.com
ALLOWED_ORIGINS=https://your-domain.com

# ===== RAG 默认参数 =====
DEFAULT_TOP_K=5
DEFAULT_CHUNK_SIZE=800
DEFAULT_CHUNK_OVERLAP=150
