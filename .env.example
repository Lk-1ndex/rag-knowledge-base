# ===== OpenAI 兼容网关（推荐）=====
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_WIRE_API=responses
OPENAI_REASONING_EFFORT=xhigh
OPENAI_DISABLE_RESPONSE_STORAGE=true

# ===== DeepSeek（可选，未设置 OPENAI_* 时使用）=====
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_EMBEDDING_MODEL=text-embedding-3-small
DEEPSEEK_CHAT_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING_MODE=non-think

# ===== 安全配置 =====
SECRET_KEY=请替换为64位随机十六进制字符串
JWT_EXPIRE_DAYS=7

# ===== 初始管理员账号 =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请修改为强密码123A

# ===== Qdrant =====
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=research_kb

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== 限流配置 =====
RATE_LIMIT_PER_MINUTE=30
MAX_AUTH_FAILURES=5
AUTH_BAN_MINUTES=15

# ===== 文件上传 =====
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/app/data/uploads

# ===== SQLite =====
SQLITE_PATH=/app/data/sqlite/db.sqlite3

# ===== 应用配置 =====
APP_TITLE=研究组知识库
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173,http://localhost

# ===== RAG 默认参数 =====
DEFAULT_TOP_K=5
DEFAULT_CHUNK_SIZE=800
DEFAULT_CHUNK_OVERLAP=150
